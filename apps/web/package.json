{
  "name": "@speech/web",
  "version": "0.1.0",
  "private": true,
  "description": "Installable local-first speech-to-text PWA shell.",
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "chromium-smoke": "playwright test"
  },
  "dependencies": {
    "@speech/audio": "workspace:*",
    "@speech/benchmark": "workspace:*",
    "@speech/browser-training": "workspace:*",
    "@speech/context-bias": "workspace:*",
    "@speech/enrollment": "workspace:*",
    "@speech/features": "workspace:*",
    "@speech/inference": "workspace:*",
    "@speech/model-manager": "workspace:*",
    "@speech/personalization": "workspace:*",
    "@speech/profile-manager": "workspace:*",
    "@speech/protocol": "workspace:*",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6"
  }
}
