{
  "name": "@speech/ui",
  "version": "0.6.3",
  "private": true,
  "description": "Semantic UI tokens and accessible frontend primitives for the task-first speech PWA.",
  "type": "module",
  "license": "Apache-2.0",
  "exports": {
    ".": "./src/index.ts",
    "./feedback": "./src/feedback/index.ts",
    "./feedback.css": "./src/feedback/index.css",
    "./primitives": "./src/primitives/index.ts",
    "./primitives.css": "./src/primitives/index.css",
    "./testing": "./src/testing/index.ts",
    "./tokens.css": "./src/tokens/index.css",
    "./tokens/*": "./src/tokens/*.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --exclude=dist/**"
  },
  "peerDependencies": {
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
